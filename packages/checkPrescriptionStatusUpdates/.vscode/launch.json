{
  "version": "0.2.0",
  "configurations": [
      {
          "type": "node",
          "name": "vitest: all tests",
          "request": "launch",
          "program": "${workspaceFolder}/../../node_modules/vitest/vitest.mjs",
          "args": [
              "run",
              "--config",
              "${workspaceFolder}/vitest.config.ts"
          ],
          "cwd": "${workspaceFolder}",
          "console": "integratedTerminal",
          "internalConsoleOptions": "neverOpen",
          "env": {
              "POWERTOOLS_DEV": "true"
          }
      },
      {
          "type": "node",
          "name": "vitest: current file",
          "request": "launch",
          "program": "${workspaceFolder}/../../node_modules/vitest/vitest.mjs",
          "args": [
              "run",
              "--config",
              "${workspaceFolder}/vitest.config.ts",
              "${file}"
          ],
          "cwd": "${workspaceFolder}",
          "console": "integratedTerminal",
          "internalConsoleOptions": "neverOpen",
          "env": {
              "POWERTOOLS_DEV": "true"
          }
      }
  ]
}
